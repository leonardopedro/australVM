module ManagedCell is
    import Austral.Memory (
        Address,
        Pointer,
        allocate,
        load,
        store,
        nullCheck
    );

    record State is
        counter: Int64;
    end;

    function cell_alloc(): Address[State] is
        return allocate();
    end;

    function cell_step(state_addr: Address[State]): Unit is
        case nullCheck(state_addr) of
            when Some(ptr: Pointer[State]) do
                let s: State := load(ptr);
                let new_s: State := State(counter => s.counter + 1);
                store(ptr, new_s);
            when None do
                nil;
        end case;
        return nil;
    end;

    function cell_save(state_addr: Address[State]): Address[State] is
        -- In a real Theseus-like scenario, this might serialize to a different buffer.
        -- For this demo, we return the address itself as the 'serialized' state handle.
        return state_addr;
    end;

    function cell_restore(state_addr: Address[State], serialized: Address[State]): Unit is
        -- Here we would copy from 'serialized' back into 'state_addr'.
        return nil;
    end;
end module.
