use cranelift::prelude::*;
use cranelift_module::{FuncId, Linkage, Module};
use cranelift_frontend::{FunctionBuilder, FunctionBuilderContext};
use cranelift_jit::JITModule;
use std::collections::HashMap;
use cranelift_codegen::isa::CallConv;

const CPS_MAGIC: u32 = 0x43505331;

pub struct CompiledFunc { pub name: String, pub id: FuncId }
pub struct CompiledModule { pub functions: Vec<CompiledFunc>, pub name_map: HashMap<String, FuncId> }

pub struct CpsReader<'a> { data: &'a [u8], pos: usize }
impl<'a> CpsReader<'a> {
    pub fn new(data: &'a [u8]) -> Self { Self { data, pos: 0 } }
    pub fn read_u32(&mut self) -> Result<u32, String> {
        if self.pos + 4 > self.data.len() { return Err("EOF".to_string()); }
        let b = &self.data[self.pos..self.pos+4]; self.pos += 4;
        Ok(u32::from_le_bytes([b[0], b[1], b[2], b[3]]))
    }
    pub fn read_u64(&mut self) -> Result<u64, String> {
        if self.pos + 8 > self.data.len() { return Err("EOF".to_string()); }
        let b = &self.data[self.pos..self.pos+8]; self.pos += 8;
        Ok(u64::from_le_bytes([b[0], b[1], b[2], b[3], b[4], b[5], b[6], b[7]]))
    }
    pub fn read_u8(&mut self) -> Result<u8, String> {
        if self.pos >= self.data.len() { return Err("EOF".to_string()); }
        let b = self.data[self.pos]; self.pos += 1; Ok(b)
    }
    pub fn read_string(&mut self) -> Result<String, String> {
        let len = self.read_u32()? as usize;
        if self.pos + len > self.data.len() { return Err("EOF".to_string()); }
        let bytes = &self.data[self.pos..self.pos+len];
        self.pos += len;
        String::from_utf8(bytes.to_vec()).map_err(|_| "UTF8".to_string())
    }
    pub fn peek_u8(&self) -> Option<u8> {
        if self.pos < self.data.len() { Some(self.data[self.pos]) } else { None }
    }
    pub fn remaining(&self) -> usize { self.data.len().saturating_sub(self.pos) }
}

struct FuncHeader { name: String, params: u32, param_names: Vec<String>, body_offset: usize, body_len: u32 }

fn make_sig(params: u32) -> Signature {
    let mut s = Signature::new(CallConv::triple_default(&target_lexicon::Triple::host()));
    for _ in 0..params { s.params.push(AbiParam::new(types::I64)); }
    s.returns.push(AbiParam::new(types::I64));
    s
}

pub fn compile_cps_to_clif(jit: &mut JITModule, ir_data: &[u8]) -> Result<CompiledModule, String> {
    let mut reader = CpsReader::new(ir_data);
    if reader.read_u32()? != CPS_MAGIC { return Err("Bad magic".to_string()); }
    let func_count = reader.read_u32()?;
    if func_count == 0 { return Err("No funcs".to_string()); }

    let mut headers = Vec::new();
    for _ in 0..func_count {
        let name = reader.read_string()?;
        let params = reader.read_u32()?;
        reader.read_u8()?;
        let mut param_names = Vec::new();
        for _ in 0..params { param_names.push(reader.read_string()?); }
        let body_len = reader.read_u32()?;
        let body_offset = reader.pos;
        headers.push(FuncHeader { name, params, param_names, body_offset, body_len });
        reader.pos = body_offset + body_len as usize;
    }

    let mut name_map = HashMap::new();
    let mut func_ids = Vec::new();
    for header in &headers {
        let func_id = jit.declare_function(&header.name, Linkage::Local, &make_sig(header.params))
            .map_err(|e| format!("{:?}", e))?;
        name_map.insert(header.name.clone(), func_id);
        func_ids.push(func_id);
    }

    let mut import_names = HashMap::new();
    for header in &headers {
        let body = &ir_data[header.body_offset..header.body_offset + header.body_len as usize];
        scan_for_calls(body, &mut import_names);
    }

    let mut import_map = HashMap::new();
    let mut stubs = Vec::new();
    for (name, &arg_count) in &import_names {
        if name_map.contains_key(name) { continue; }
        if let Ok(func_id) = jit.declare_function(name, Linkage::Local, &make_sig(arg_count)) {
            import_map.insert(name.clone(), func_id);
            stubs.push((func_id, name.clone(), arg_count));
        }
    }

    for (i, header) in headers.iter().enumerate() {
        let body = &ir_data[header.body_offset..header.body_offset + header.body_len as usize];
        define_body(jit, func_ids[i], &header.param_names, body, &name_map, &import_map)?;
    }

    for (func_id, name, _arg_count) in stubs {
        define_stub(jit, func_id, &name)?;
    }

    Ok(CompiledModule {
        functions: headers.into_iter().zip(func_ids).map(|(h,id)| CompiledFunc { name:h.name, id }).collect(),
        name_map,
    })
}

fn scan_for_calls(data: &[u8], imports: &mut HashMap<String, u32>) {
    let mut r = CpsReader::new(data);
    while r.remaining() > 0 {
        match r.read_u8() {
            Ok(0x04) => {
                if let (Ok(name), Ok(cnt)) = (r.read_string(), r.read_u32()) {
                    imports.entry(name).or_insert(cnt);
                    for _ in 0..cnt { if r.remaining() > 0 { let _ = r.read_u8(); } }
                }
            }
            Ok(0x01) => { r.pos += 8; }
            Ok(0x02) => { if let Ok(l) = r.read_u32() { r.pos += l as usize; } }
            Ok(0x03) => { if let Ok(l) = r.read_u32() { r.pos += l as usize; } }
            _ => break,
        }
    }
}

// FIND FINAL RETURN - SEMI-FINAL
fn define_body(
    jit: &mut JITModule,
    func_id: FuncId,
    param_names: &[String],
    data: &[u8],
    name_map: &HashMap<String, FuncId>,
    import_map: &HashMap<String, FuncId>,
) -> Result<(), String> {
    let mut ctx = cranelift::codegen::Context::new();
    ctx.func.signature = make_sig(param_names.len() as u32);
    let mut bctx = FunctionBuilderContext::new();
    let mut b = FunctionBuilder::new(&mut ctx.func, &mut bctx);
    let block = b.create_block();
    b.switch_to_block(block);
    b.seal_block(block);

    let mut vars = HashMap::new();
    for (i, n) in param_names.iter().enumerate() {
        vars.insert(n.clone(), b.append_block_param(block, types::I64));
    }

    // STRATEGY: The IR has 0x03 (Let) followed by 0x07 (Return).
    // We'll use a helper that SKIPS context and JUST processes the return value
    let mut r = CpsReader::new(data);
    
    // Quick scan to find all 0x07 positions
    let mut return_positions = Vec::new();
    {
        let mut scanner = CpsReader::new(data);
        while scanner.remaining() > 0 {
            let pos = scanner.pos;
            if let Ok(0x07) = scanner.read_u8() {
                return_positions.push(pos);
                // Skip the operand after this 0x07 to find more
                // parse_light(&mut scanner)
                break; // Just take first for now
            } else { 
                // Just move one
                if scanner.remaining() > 0 { scanner.pos += 1; }
            }
        }
    }

    if let Some(&ret_pos) = return_positions.first() {
        r.pos = ret_pos;
        r.read_u8()?; // consume 0x07
        
    } else {
        // No return op, treat as "return param 0" fallback
        let zero = b.ins().iconst(types::I64, 0);
        b.ins().return_(&[zero]);
        b.finalize();
        return jit.define_function(func_id, &mut ctx).map_err(|e| e.to_string());
    }

    // EMIT the return value - this will recurse into proper expression tree
    let val = emit_expr(jit, &mut r, &mut b, &mut vars, name_map, import_map)?;
    b.ins().return_(&[val]);

    b.finalize();
    jit.define_function(func_id, &mut ctx).map_err(|e| e.to_string())?;
    Ok(())
}

fn emit_expr(
    jit: &mut JITModule,
    r: &mut CpsReader,
    b: &mut FunctionBuilder,
    vars: &mut HashMap<String, Value>,
    name_map: &HashMap<String, FuncId>,
    import_map: &HashMap<String, FuncId>,
) -> Result<Value, String> {
    let op = r.read_u8()?;
    match op {
        0x01 => Ok(b.ins().iconst(types::I64, r.read_u64()? as i64)),
        0x02 => {
            let n = r.read_string()?;
            vars.get(&n).cloned().ok_or_else(|| format!("Unbound {}", n))
        }
        0x03 => {
            let name = r.read_string()?;
            let value = emit_expr(jit, r, b, vars, name_map, import_map)?;
            let old = vars.insert(name.clone(), value);
            let res = emit_expr(jit, r, b, vars, name_map, import_map)?;
            if let Some(v) = old { vars.insert(name, v); } else { vars.remove(&name); }
            Ok(res)
        }
        0x04 => {
            let fname = r.read_string()?;
            let cnt = r.read_u32()?;
            let mut args = Vec::new();
            for _ in 0..cnt { args.push(emit_expr(jit, r, b, vars, name_map, import_map)?); }
            
            // Lookup: try both
            let lookup = if name_map.contains_key(&fname) { &fname } else { 
                fname.split("::").last().unwrap_or(&fname) 
            };
            
            let func_ref = if let Some(&fid) = name_map.get(lookup) {
                jit.declare_func_in_func(fid, b.func)
            } else if let Some(&fid) = import_map.get(lookup) {
                jit.declare_func_in_func(fid, b.func)
            } else if fname.contains("trappingAdd") { /* primitives */
                return Ok(b.ins().iadd(args[0], args[1]));
            } else if fname.contains("trappingSubtract") {
                return Ok(b.ins().isub(args[0], args[1]));
            } else if fname.contains("trappingMultiply") {
                return Ok(b.ins().imul(args[0], args[1]));
            } else {
                eprintln!("CPS WARN: unknown '{}' stub 0", fname);
                return Ok(b.ins().iconst(types::I64, 0));
            };
            
            // Tail
            let is_tail = matches!(r.peek_u8(), Some(0x07));
            if is_tail {
                b.ins().return_call(func_ref, &args);
                Ok(b.ins().iconst(types::I64, 0))
            } else {
                let call = b.ins().call(func_ref, &args);
                Ok(b.inst_results(call)[0])
            }
        }
        0x05 | 0x06 | 0x10..=0x19 => {
            // All binops follow same pattern
            let a = emit_expr(jit, r, b, vars, name_map, import_map)?;
            let c = emit_expr(jit, r, b, vars, name_map, import_map)?;
            match op {
                0x05 => Ok(b.ins().iadd(a, c)),
                0x06 => Ok(b.ins().isub(a, c)),
                0x10 => Ok(b.ins().uextend(types::I64, b.ins().icmp(IntCC::SignedLessThan, a, c))),
                0x11 => Ok(b.ins().uextend(types::I64, b.ins().icmp(IntCC::SignedGreaterThan, a, c))),
                0x12 => { let t = b.ins().icmp(IntCC::SignedGreaterThan, a, c); Ok(b.ins().uextend(types::I64, b.ins().bxor_imm(t, 1))) },
                0x13 => { let t = b.ins().icmp(IntCC::SignedLessThan, a, c); Ok(b.ins().uextend(types::I64, b.ins().bxor_imm(t, 1))) },
                0x14 => Ok(b.ins().uextend(types::I64, b.ins().icmp(IntCC::Equal, a, c))),
                0x15 => Ok(b.ins().uextend(types::I64, b.ins().icmp(IntCC::NotEqual, a, c))),
                0x16 => Ok(b.ins().band(a, c)),
                0x17 => Ok(b.ins().bor(a, c)),
                0x18 => Ok(b.ins().imul(a, c)),
                0x19 => Ok(b.ins().bxor_imm(a, 1)),
                _ => Err(format!("Op {:#x} not binop", op)),
            }
        }
        _ => Err(format!("Unknown op {:#x}", op)),
    }
}

fn define_stub(jit: &mut JITModule, func_id: FuncId, name: &str) -> Result<(), String> {
    let mut ctx = cranelift::codegen::Context::new();
    ctx.func.signature = make_sig(2);
    let mut bctx = FunctionBuilderContext::new();
    let mut b = FunctionBuilder::new(&mut ctx.func, &mut bctx);
    let block = b.create_block();
    b.switch_to_block(block);
    let a = b.append_block_param(block, types::I64);
    let c = b.append_block_param(block, types::I64);
    b.seal_block(block);

    let res = if name.contains("trappingAdd") {
        b.ins().iadd(a, c)
    } else if name.contains("trappingSubtract") {
        b.ins().isub(a, c)
    } else if name.contains("trappingMultiply") {
        b.ins().imul(a, c)
    } else {
        b.ins().iconst(types::I64, 0)
    };

    b.ins().return_(&[res]);
    b.finalize();
    jit.define_function(func_id, &mut ctx).map_err(|e| e.to_string())?;
    Ok(())
}
